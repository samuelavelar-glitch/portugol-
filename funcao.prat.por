programa
{
    funcao verifica_numero(real numero )
    {
      se(numero<0){
   escreva("\nnegativos") 
  } senao {
   	escreva("\npositivos")
      
    }
   
    }
   
   funcao inicio()
	{
    real numero_digitado
  
  escreva("digite um numero")
   
    leia(numero_digitado)
   verifica_numero(numero_digitado)

	}
    
     }
